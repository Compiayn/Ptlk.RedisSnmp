{
  "ConnectionStrings": {
    "DefaultConnection": "Data Source=redis-snmp-dev.db"
  },
  "StartupGate": {
    "WaitInitializedTimeoutMs": 3000,
    "InitialRetryDelayMs": 250,
    "MaxRetryDelayMs": 1000
  },
  "RedisSnmpRuntime": {
    "HeartbeatIntervalMs": 5000,
    "CommandDefaultTimeoutMs": 5000
  },
  "NetSnmp": {
    "MibDirectory": "mibs",
    "WorkDirectory": "snmp-work"
  },
  "Trap": {
    "Enabled": false,
    "ListenPort": 10162,
    "BufferLimit": 1000
  },
  "DataProtection": {
    "KeysPath": "data-protection-keys"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore.Database.Command": "Warning"
    }
  }
}
