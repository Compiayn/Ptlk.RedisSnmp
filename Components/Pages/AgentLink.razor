@page "/agent-link"
@rendermode InteractiveServer
@inject SnmpCredentialService Credentials
@inject SnmpAgentService Agents
@inject SnmpPointService Points
@inject SnmpClientService SnmpClient
@inject MibSetService MibSets
@inject MibLookupService MibLookup
@inject SnmpSourcePathService Paths
@inject ScreenAlertService ScreenAlerts

<div class="page-header">
    <div>
        <h1>AgentLink</h1>
        <p class="page-kicker">SNMP credentials, agents, and points are managed as separate configuration records.</p>
    </div>
</div>

<ScreenAlertHost />

<div class="toolbar">
    <div>
        <h2 class="toolbar-title">Credentials</h2>
        <div class="muted-metadata">Secrets are never displayed; leave password fields blank to keep existing values.</div>
    </div>
    <button class="btn btn-primary" type="button" @onclick="() => OpenCredentialDialog()">Add Credential</button>
</div>

@if (credentials.Count == 0)
{
    <div class="empty-state">No SNMP credentials are configured.</div>
}
else
{
    <div class="table-responsive">
        <table class="table table-sm data-table align-middle">
            <thead>
                <tr>
                    <th>Name</th>
                    <th>Version</th>
                    <th>Security</th>
                    <th>Description</th>
                    <th class="numeric">Updated</th>
                    <th class="actions">Actions</th>
                </tr>
            </thead>
            <tbody>
            @foreach (var item in credentials)
            {
                <tr>
                    <td>@item.Name</td>
                    <td><span class="status-badge neutral">@item.Version</span></td>
                    <td>@SecuritySummary(item)</td>
                    <td>@(item.Description ?? "-")</td>
                    <td class="numeric">@FormatDate(item.UpdatedAt)</td>
                    <td class="actions">
                        <button class="btn btn-sm btn-outline-secondary" type="button" @onclick="() => OpenCredentialDialog(item)">Edit</button>
                        <button class="btn btn-sm btn-outline-danger" type="button" @onclick="() => OpenCredentialDeleteDialog(item)">Delete</button>
                    </td>
                </tr>
            }
            </tbody>
        </table>
    </div>
}

<div class="toolbar">
    <div>
        <h2 class="toolbar-title">Agents</h2>
        <div class="muted-metadata">Connection status is evaluated by runtime polling, not by this configuration grid.</div>
    </div>
    <button class="btn btn-primary" type="button" @onclick="() => OpenAgentDialog()">Add Agent</button>
</div>

@if (agents.Count == 0)
{
    <div class="empty-state">No SNMP agents are configured.</div>
}
else
{
    <div class="table-responsive">
        <table class="table table-sm data-table align-middle">
            <thead>
                <tr>
                    <th>Agent ID</th>
                    <th>Display name</th>
                    <th>Endpoint</th>
                    <th>Credential</th>
                    <th>Preferred MIB</th>
                    <th>Status</th>
                    <th class="numeric">Poll ms</th>
                    <th class="numeric">Points</th>
                    <th class="actions">Actions</th>
                </tr>
            </thead>
            <tbody>
            @foreach (var item in agents)
            {
                <tr class='@(generateDialogOpen && generateAgent?.Id == item.Id ? "selected-row" : null)'>
                    <td><code>@item.AgentId</code></td>
                    <td>@item.DisplayName</td>
                    <td>@item.Host:@item.Port</td>
                    <td>@(item.CredentialConfig?.Name ?? "-")</td>
                    <td>@MibSetName(item.PreferredMibSetId)</td>
                    <td><span class="@StatusBadgeClass(item.Enabled ? "normal" : "disabled")">@(item.Enabled ? "enabled" : "disabled")</span></td>
                    <td class="numeric">@item.PollingRateMs</td>
                    <td class="numeric">@item.Points.Count</td>
                    <td class="actions">
                        <button class="btn btn-sm btn-outline-primary" type="button" @onclick="() => OpenWalkDialog(item)">Walk</button>
                        <button class="btn btn-sm btn-outline-primary" type="button" @onclick="() => OpenGenerateDialog(item)">Edit Points</button>
                        <button class="btn btn-sm btn-outline-secondary" type="button" @onclick="() => OpenAgentDialog(item)">Edit</button>
                        <button class="btn btn-sm btn-outline-danger" type="button" @onclick="() => OpenAgentDeleteDialog(item)">Delete</button>
                    </td>
                </tr>
            }
            </tbody>
        </table>
    </div>
}

@if (credentialDialogOpen)
{
    <div class="dialog-backdrop" @onclick="CloseCredentialDialog"></div>
    <div class="dialog-panel" role="dialog" aria-modal="true">
        <div class="dialog-header">
            <div>
                <h2 class="m-0">@((credential.Id > 0) ? "Edit Credential" : "Add Credential")</h2>
                <div class="muted-metadata">Secret fields are write-only.</div>
            </div>
            <button class="btn-close" type="button" aria-label="Close" @onclick="CloseCredentialDialog"></button>
        </div>
        <div class="dialog-body">
            <div class="row g-3">
                <div class="col-md-6">
                    <label class="form-label">Name</label>
                    <input class="form-control" @bind="credential.Name" />
                </div>
                <div class="col-md-6">
                    <label class="form-label">SNMP version</label>
                    <select class="form-select" @bind="credential.Version">
                        <option value="@SnmpVersions.V1">v1</option>
                        <option value="@SnmpVersions.V2C">v2c</option>
                        <option value="@SnmpVersions.V3">v3</option>
                    </select>
                </div>
                @if (credential.Version == SnmpVersions.V1 || credential.Version == SnmpVersions.V2C)
                {
                    <div class="col-12">
                        <label class="form-label">Read community</label>
                        <input class="form-control" type="password" @bind="readCommunity" autocomplete="new-password" />
                        <div class="form-text">Used by SNMP Get and Walk. Leave blank while editing to keep the stored value.</div>
                    </div>
                    <div class="col-12">
                        <label class="form-label">Write community</label>
                        <input class="form-control" type="password" @bind="writeCommunity" autocomplete="new-password" />
                        <div class="form-text">Used by SNMP Set. Leave blank while editing to keep the stored value.</div>
                    </div>
                }
                @if (credential.Version == SnmpVersions.V3)
                {
                    <div class="col-md-6">
                        <label class="form-label">Security name</label>
                        <input class="form-control" @bind="credential.SecurityName" />
                    </div>
                    <div class="col-md-6">
                        <label class="form-label">Security level</label>
                        <select class="form-select" @bind="credential.SecurityLevel">
                            <option value="@SnmpSecurityLevels.NoAuthNoPriv">noAuthNoPriv</option>
                            <option value="@SnmpSecurityLevels.AuthNoPriv">authNoPriv</option>
                            <option value="@SnmpSecurityLevels.AuthPriv">authPriv</option>
                        </select>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label">Auth protocol</label>
                        <input class="form-control" @bind="credential.AuthProtocol" placeholder="SHA" />
                    </div>
                    <div class="col-md-6">
                        <label class="form-label">Auth password</label>
                        <input class="form-control" type="password" @bind="authPassword" autocomplete="new-password" />
                    </div>
                    <div class="col-md-6">
                        <label class="form-label">Privacy protocol</label>
                        <input class="form-control" @bind="credential.PrivProtocol" placeholder="AES" />
                    </div>
                    <div class="col-md-6">
                        <label class="form-label">Privacy password</label>
                        <input class="form-control" type="password" @bind="privPassword" autocomplete="new-password" />
                    </div>
                }
                <div class="col-12">
                    <label class="form-label">Description</label>
                    <textarea class="form-control" rows="2" @bind="credential.Description"></textarea>
                </div>
            </div>
        </div>
        <div class="dialog-footer">
            <button class="btn btn-outline-secondary" type="button" @onclick="CloseCredentialDialog">Cancel</button>
            <button class="btn btn-primary" type="button" @onclick="SaveCredentialAsync">Save</button>
        </div>
    </div>
}

@if (agentDialogOpen)
{
    <div class="dialog-backdrop" @onclick="CloseAgentDialog"></div>
    <div class="dialog-panel wide" role="dialog" aria-modal="true">
        <div class="dialog-header">
            <div>
                <h2 class="m-0">@((agent.Id > 0) ? "Edit Agent" : "Add Agent")</h2>
                <div class="muted-metadata">Runtime health is shown on Browser and Status after polling.</div>
            </div>
            <button class="btn-close" type="button" aria-label="Close" @onclick="CloseAgentDialog"></button>
        </div>
        <div class="dialog-body">
            <div class="row g-3">
                <div class="col-md-4">
                    <label class="form-label">Agent ID</label>
                    <input class="form-control" @bind="agent.AgentId" />
                </div>
                <div class="col-md-4">
                    <label class="form-label">Display name</label>
                    <input class="form-control" @bind="agent.DisplayName" />
                </div>
                <div class="col-md-4">
                    <label class="form-label">Credential</label>
                    <select class="form-select" @bind="agent.CredentialConfigId">
                        <option value="">No credential</option>
                        @foreach (var item in credentials)
                        {
                            <option value="@item.Id">@item.Name</option>
                        }
                    </select>
                </div>
                <div class="col-md-4">
                    <label class="form-label">Preferred MIB Set</label>
                    <select class="form-select" @bind="agent.PreferredMibSetId">
                        <option value="">Numeric OID only</option>
                        @foreach (var item in mibSetOptions)
                        {
                            <option value="@item.Id">@item.Name (@item.Status)</option>
                        }
                    </select>
                </div>
                <div class="col-md-6">
                    <label class="form-label">Host</label>
                    <input class="form-control" @bind="agent.Host" />
                </div>
                <div class="col-md-2">
                    <label class="form-label">Port</label>
                    <input class="form-control numeric" type="number" @bind="agent.Port" />
                </div>
                <div class="col-md-4">
                    <label class="form-label">SNMP version</label>
                    <select class="form-select" @bind="agent.SnmpVersion">
                        <option value="@SnmpVersions.V1">v1</option>
                        <option value="@SnmpVersions.V2C">v2c</option>
                        <option value="@SnmpVersions.V3">v3</option>
                    </select>
                </div>
                <div class="col-md-4">
                    <label class="form-label">Timeout ms</label>
                    <input class="form-control numeric" type="number" @bind="agent.TimeoutMs" />
                </div>
                <div class="col-md-4">
                    <label class="form-label">Retries</label>
                    <input class="form-control numeric" type="number" @bind="agent.RetryCount" />
                </div>
                <div class="col-md-4">
                    <label class="form-label">Polling rate ms</label>
                    <input class="form-control numeric" type="number" @bind="agent.PollingRateMs" />
                </div>
                <div class="col-12">
                    <div class="form-check form-switch">
                        <input class="form-check-input" id="agent-enabled" type="checkbox" @bind="agent.Enabled" />
                        <label class="form-check-label" for="agent-enabled">Enabled</label>
                    </div>
                </div>
                <div class="col-12">
                    <label class="form-label">Description</label>
                    <textarea class="form-control" rows="2" @bind="agent.Description"></textarea>
                </div>
            </div>
        </div>
        <div class="dialog-footer">
            <button class="btn btn-outline-secondary" type="button" @onclick="CloseAgentDialog">Cancel</button>
            <button class="btn btn-primary" type="button" @onclick="SaveAgentAsync">Save</button>
        </div>
    </div>
}

@if (pointDialogOpen)
{
    <div class="dialog-backdrop nested-dialog-backdrop" @onclick="ClosePointDialog"></div>
    <div class="dialog-panel wide nested-dialog-panel" role="dialog" aria-modal="true">
        <div class="dialog-header">
            <div>
                <h2 class="m-0">@((point.Id > 0) ? "Edit Point" : "Add Point")</h2>
                <div class="muted-metadata">Mapping to Redis is configured separately.</div>
            </div>
            <button class="btn-close" type="button" aria-label="Close" @onclick="ClosePointDialog"></button>
        </div>
        <div class="dialog-body">
            <div class="row g-3">
                <div class="col-md-4">
                    <label class="form-label">Agent</label>
                    <select class="form-select" @bind="point.AgentConfigId" disabled="@(generateDialogOpen && generateAgent is not null)">
                        <option value="0">Select agent</option>
                        @foreach (var item in agents)
                        {
                            <option value="@item.Id">@item.AgentId</option>
                        }
                    </select>
                </div>
                <div class="col-md-4">
                    <label class="form-label">Point name</label>
                    <input class="form-control" @bind="point.PointName" />
                </div>
                <div class="col-md-4">
                    <label class="form-label">Numeric OID</label>
                    <input class="form-control" @bind="point.NumericOid" />
                </div>
                <div class="col-md-4">
                    <label class="form-label">Value type</label>
                    <select class="form-select" @bind="point.ValueType">
                        <option value="@SnmpValueTypes.String">string</option>
                        <option value="@SnmpValueTypes.Integer">integer</option>
                        <option value="@SnmpValueTypes.Double">double</option>
                        <option value="@SnmpValueTypes.Boolean">boolean</option>
                        <option value="@SnmpValueTypes.Timeticks">timeticks</option>
                        <option value="@SnmpValueTypes.Oid">oid</option>
                    </select>
                </div>
                <div class="col-md-4">
                    <label class="form-label">Access</label>
                    <select class="form-select" @bind="point.Access">
                        <option value="@SnmpAccessModes.ReadOnly">ro</option>
                        <option value="@SnmpAccessModes.ReadWrite">rw</option>
                        <option value="@SnmpAccessModes.WriteOnly">wo</option>
                    </select>
                </div>
                <div class="col-md-4">
                    <label class="form-label">Mapping MIB Set</label>
                    <select class="form-select" @bind="point.MibSetIdUsedForMapping">
                        <option value="">Numeric OID only</option>
                        @foreach (var item in mibSetOptions)
                        {
                            <option value="@item.Id">@item.Name (@item.Status)</option>
                        }
                    </select>
                </div>
                <div class="col-md-4">
                    <label class="form-label">MIB label</label>
                    <input class="form-control" @bind="point.MibLabel" />
                </div>
                <div class="col-md-4">
                    <label class="form-label">MIB module</label>
                    <input class="form-control" @bind="point.MibModule" />
                </div>
                <div class="col-md-4">
                    <label class="form-label">MIB syntax</label>
                    <input class="form-control" @bind="point.MibSyntax" />
                </div>
                <div class="col-md-4">
                    <label class="form-label">MIB access</label>
                    <input class="form-control" @bind="point.MibAccess" />
                </div>
                <div class="col-12">
                    <label class="form-label">Description</label>
                    <textarea class="form-control" rows="2" @bind="point.Description"></textarea>
                </div>
            </div>
        </div>
        <div class="dialog-footer">
            <button class="btn btn-outline-secondary" type="button" @onclick="ClosePointDialog">Cancel</button>
            <button class="btn btn-primary" type="button" @onclick="SavePointAsync">Save</button>
        </div>
    </div>
}

@if (walkDialogOpen && walkAgent is not null)
{
    <div class="dialog-backdrop" @onclick="CloseWalkDialog"></div>
    <div class="dialog-panel extra-wide" role="dialog" aria-modal="true">
        <div class="dialog-header">
            <div>
                <h2 class="m-0">Walk @walkAgent.DisplayName</h2>
                <div class="muted-metadata">@walkAgent.Host:@walkAgent.Port / @walkAgent.SnmpVersion / @(walkAgent.CredentialConfig?.Name ?? "No credential")</div>
            </div>
            <button class="btn-close" type="button" aria-label="Close" @onclick="CloseWalkDialog"></button>
        </div>
        <div class="dialog-body">
            <div class="walk-controls">
                <div>
                    <label class="form-label">Root OID</label>
                    <input class="form-control" @bind="walkRootOid" disabled="@walkRunning" />
                </div>
                <div>
                    <label class="form-label">MIB Set</label>
                    <select class="form-select" value="@MibSetSelectValue(walkSelectedMibSetId)" @onchange="OnWalkMibSetChanged" disabled="@walkRunning">
                        <option value="">Numeric OID only</option>
                        @foreach (var item in mibSetOptions)
                        {
                            <option value="@item.Id">@item.Name (@item.Status)</option>
                        }
                    </select>
                </div>
                <div>
                    <label class="form-label">Operation timeout ms</label>
                    <input class="form-control numeric" type="number" @bind="walkOperationTimeoutMs" disabled="@walkRunning" />
                </div>
                <div class="walk-control-actions">
                    <button class="btn btn-primary" type="button" @onclick="RunWalkAsync" disabled="@walkRunning">@(walkRunning ? "Walking..." : "Walk")</button>
                    <button class="btn btn-outline-secondary" type="button" @onclick="ExpandWalkTree" disabled="@(walkTree.Count == 0)">Expand all</button>
                    <button class="btn btn-outline-secondary" type="button" @onclick="CollapseWalkTree" disabled="@(walkTree.Count == 0)">Collapse all</button>
                </div>
            </div>

            @if (!string.IsNullOrWhiteSpace(walkError))
            {
                <div class="alert alert-danger">@walkError</div>
            }
            else if (walkRunning)
            {
                <div class="empty-state">Running SNMP Walk...</div>
            }
            else if (walkResult?.Success == true)
            {
                <div class="walk-summary">
                    <span class="status-badge success">@walkResult.Items.Count item(s)</span>
                    <code>@NormalizeOidForDisplay(walkRootOid)</code>
                </div>
                @if (walkTree.Count == 0)
                {
                    <div class="empty-state">No objects were returned.</div>
                }
                else
                {
                    <div class="walk-tree" role="tree">
                        @foreach (var row in VisibleWalkRows)
                        {
                            var node = row.Node;
                            var hasChildren = node.Children.Count > 0;
                            var isExpanded = expandedWalkNodes.Contains(node.Oid);
                            <div class="walk-tree-row @(node.Item is null ? "branch" : "leaf")" style="@($"--walk-depth:{row.Depth}")" role="treeitem" aria-expanded="@(hasChildren ? isExpanded.ToString().ToLowerInvariant() : null)">
                                <button class="walk-toggle" type="button" disabled="@(!hasChildren)" @onclick="() => ToggleWalkNode(node.Oid)">@(hasChildren ? (isExpanded ? "-" : "+") : "")</button>
                                <div class="walk-node-main">
                                    <div class="walk-node-title">
                                        <span class="walk-segment">@node.Segment</span>
                                        <code>@node.Oid</code>
                                        @if (!string.IsNullOrWhiteSpace(node.Lookup?.SymbolicName))
                                        {
                                            <span class="walk-label">@node.Lookup.SymbolicName</span>
                                        }
                                        @if (!string.IsNullOrWhiteSpace(node.Lookup?.ModuleName))
                                        {
                                            <span class="status-badge neutral">@node.Lookup.ModuleName</span>
                                        }
                                        @if (!string.IsNullOrWhiteSpace(node.Lookup?.Syntax ?? node.Item?.Syntax))
                                        {
                                            <span class="status-badge neutral">@(node.Lookup?.Syntax ?? node.Item?.Syntax)</span>
                                        }
                                    </div>
                                    @if (node.Item is not null)
                                    {
                                        <div class="walk-node-value">@node.Item.Value</div>
                                    }
                                    @if (!string.IsNullOrWhiteSpace(node.Lookup?.Description))
                                    {
                                        <div class="muted-metadata">@node.Lookup.Description</div>
                                    }
                                </div>
                            </div>
                        }
                    </div>
                }
            }
        </div>
        <div class="dialog-footer">
            <button class="btn btn-outline-secondary" type="button" @onclick="CloseWalkDialog">@(walkRunning ? "Cancel" : "Close")</button>
        </div>
    </div>
}

@if (generateDialogOpen && generateAgent is not null)
{
    <div class="dialog-backdrop" @onclick="CloseGenerateDialog"></div>
    <div class="dialog-panel extra-wide" role="dialog" aria-modal="true">
        <div class="dialog-header">
            <div>
                <h2 class="m-0">Edit Points for @generateAgent.DisplayName</h2>
                <div class="muted-metadata">@generateAgent.Host:@generateAgent.Port / @generateAgent.SnmpVersion / @(generateAgent.CredentialConfig?.Name ?? "No credential")</div>
            </div>
            <button class="btn-close" type="button" aria-label="Close" @onclick="CloseGenerateDialog"></button>
        </div>
        <div class="dialog-body">
            @if (!string.IsNullOrWhiteSpace(pointManagerMessage))
            {
                <div class="@(pointManagerMessageIsError ? "alert alert-danger" : "alert alert-info")">@pointManagerMessage</div>
            }

            <ul class="nav nav-tabs point-manager-tabs" role="tablist">
                <li class="nav-item" role="presentation">
                    <button class='nav-link @(pointManagerTab == PointManagerPointsTab ? "active" : null)' type="button" role="tab" aria-selected="@(pointManagerTab == PointManagerPointsTab)" @onclick="ShowPointManagerPointsTab">Points (@ManagedAgentPoints.Count)</button>
                </li>
                <li class="nav-item" role="presentation">
                    <button class='nav-link @(pointManagerTab == PointManagerBuildTab ? "active" : null)' type="button" role="tab" aria-selected="@(pointManagerTab == PointManagerBuildTab)" @onclick="ShowPointManagerBuildTab">Build Points</button>
                </li>
            </ul>

            @if (pointManagerTab == PointManagerPointsTab)
            {
                <div class="toolbar point-manager-toolbar">
                    <div>
                        <h3 class="section-title">Configured Points</h3>
                        <div class="muted-metadata">Source paths are generated from agent ID and normalized numeric OID.</div>
                    </div>
                    <button class="btn btn-primary" type="button" @onclick="() => OpenPointDialog(null, generateAgent)">Add Point</button>
                </div>

                @if (ManagedAgentPoints.Count == 0)
                {
                    <div class="empty-state">No SNMP points are configured for this agent.</div>
                }
                else
                {
                    <div class="table-responsive point-manager-table">
                        <table class="table table-sm data-table align-middle">
                            <thead>
                                <tr>
                                    <th>Point</th>
                                    <th>OID</th>
                                    <th>MIB</th>
                                    <th>Value type</th>
                                    <th>Access</th>
                                    <th class="actions">Actions</th>
                                </tr>
                            </thead>
                            <tbody>
                            @foreach (var item in ManagedAgentPoints)
                            {
                                <tr class='@(pointDialogOpen && point.Id == item.Id ? "selected-row" : null)'>
                                    <td>
                                        <div>@item.PointName</div>
                                        <small>@item.SourcePath</small>
                                    </td>
                                    <td><code>@item.NumericOid</code></td>
                                    <td>
                                        <div>@(item.MibLabel ?? "-")</div>
                                        <small>@MibSetName(item.MibSetIdUsedForMapping)</small>
                                    </td>
                                    <td>@item.ValueType</td>
                                    <td><span class="status-badge neutral">@item.Access</span></td>
                                    <td class="actions">
                                        <button class="btn btn-sm btn-outline-secondary" type="button" @onclick="() => OpenPointDialog(item, generateAgent)">Edit</button>
                                        <button class="btn btn-sm btn-outline-danger" type="button" @onclick="() => OpenPointDeleteDialog(item)">Delete</button>
                                    </td>
                                </tr>
                            }
                            </tbody>
                        </table>
                    </div>
                }
            }
            else
            {
                <div class="toolbar point-manager-toolbar">
                    <div>
                        <h3 class="section-title">Build Points</h3>
                        <div class="muted-metadata">Scan this agent with SNMP Walk, review candidate objects, then apply selected rows as points.</div>
                    </div>
                </div>

                <div class="walk-controls point-build-controls">
                    <div>
                        <label class="form-label">Root OID</label>
                        <input class="form-control" @bind="generateRootOid" disabled="@generateRunning" />
                    </div>
                    <div>
                        <label class="form-label">MIB Set</label>
                        <select class="form-select" value="@MibSetSelectValue(generateSelectedMibSetId)" @onchange="OnGenerateMibSetChanged" disabled="@generateRunning">
                            <option value="">Numeric OID only</option>
                            @foreach (var item in mibSetOptions)
                            {
                                <option value="@item.Id">@item.Name (@item.Status)</option>
                            }
                        </select>
                    </div>
                    <div>
                        <label class="form-label">Timeout ms</label>
                        <input class="form-control numeric" type="number" @bind="generateOperationTimeoutMs" disabled="@generateRunning" />
                    </div>
                    <div class="walk-control-actions">
                        <button class="btn btn-primary" type="button" @onclick="RunGenerateCandidatesAsync" disabled="@generateRunning">@(generateRunning ? "Walking..." : "Scan")</button>
                    </div>
                </div>
                <div class="form-check form-switch mb-3">
                    <input class="form-check-input" id="generate-readable" type="checkbox" @bind="generateReadableOnly" disabled="@generateRunning" />
                    <label class="form-check-label" for="generate-readable">Readable objects only</label>
                </div>

                @if (!string.IsNullOrWhiteSpace(generateError))
                {
                    <div class="alert alert-danger">@generateError</div>
                }
                else if (generateRunning)
                {
                    <div class="empty-state">Running SNMP Walk...</div>
                }
                else if (pointCandidates.Count == 0)
                {
                    <div class="empty-state">No point candidates are available. Run Scan to build candidates from this agent.</div>
                }
                else
                {
                    <div class="table-responsive point-candidate-table">
                        <table class="table table-sm data-table align-middle">
                            <thead>
                                <tr>
                                    <th>Select</th>
                                    <th>OID</th>
                                    <th>Label</th>
                                    <th>Module</th>
                                    <th>Syntax</th>
                                    <th>Access</th>
                                    <th>Current value</th>
                                    <th>Point name</th>
                                    <th>Status</th>
                                </tr>
                            </thead>
                            <tbody>
                            @foreach (var candidate in pointCandidates)
                            {
                                <tr>
                                    <td>
                                        <input class="form-check-input" type="checkbox" @bind="candidate.Selected" disabled="@candidate.Exists" />
                                    </td>
                                    <td><code>@candidate.NumericOid</code></td>
                                    <td>@(candidate.Label ?? "-")</td>
                                    <td>@(candidate.Module ?? "-")</td>
                                    <td>@(candidate.Syntax ?? "-")</td>
                                    <td><span class="status-badge neutral">@candidate.Access</span></td>
                                    <td class="code-cell">@candidate.CurrentValue</td>
                                    <td><input class="form-control form-control-sm" @bind="candidate.PointName" disabled="@candidate.Exists" /></td>
                                    <td><span class="@StatusBadgeClass(candidate.Exists ? "disabled" : "normal")">@candidate.Status</span></td>
                                </tr>
                            }
                            </tbody>
                        </table>
                    </div>
                }
            }
        </div>
        <div class="dialog-footer">
            <button class="btn btn-outline-secondary" type="button" @onclick="CloseGenerateDialog">Close</button>
            @if (pointManagerTab == PointManagerBuildTab)
            {
                <button class="btn btn-primary" type="button" @onclick="ApplyGeneratedPointsAsync" disabled="@(pointCandidates.All(c => !c.Selected || c.Exists))">Apply Selected</button>
            }
        </div>
    </div>
}

@if (deleteKind is not null)
{
    <div class="dialog-backdrop" @onclick="CloseDeleteDialog"></div>
    <div class="dialog-panel" role="dialog" aria-modal="true">
        <div class="dialog-header">
            <h2 class="m-0">Confirm Delete</h2>
            <button class="btn-close" type="button" aria-label="Close" @onclick="CloseDeleteDialog"></button>
        </div>
        <div class="dialog-body">
            Delete <strong>@deleteName</strong> from @deleteKind records?
        </div>
        <div class="dialog-footer">
            <button class="btn btn-outline-secondary" type="button" @onclick="CloseDeleteDialog">Cancel</button>
            <button class="btn btn-danger" type="button" @onclick="ConfirmDeleteAsync">Delete</button>
        </div>
    </div>
}

@code {
