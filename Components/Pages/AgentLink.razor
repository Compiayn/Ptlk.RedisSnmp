    private void ShowPointManagerPointsTab() => pointManagerTab = PointManagerPointsTab;

    private void ShowPointManagerBuildTab() => pointManagerTab = PointManagerBuildTab;

    private async Task RunWalkAsync()
    {
        if (walkAgent is null)
        {
            return;
        }

        try
        {
            var rootOid = NormalizeWalkRootOid(walkRootOid);
            var timeoutMs = NormalizeWalkOperationTimeoutMs(walkOperationTimeoutMs);
            walkRootOid = rootOid;
            walkOperationTimeoutMs = timeoutMs;
            walkRunning = true;
            walkError = null;
            walkResult = null;
            walkTree = [];
            expandedWalkNodes = [];
            walkLookupByOid = new Dictionary<string, MibLookupResult>(StringComparer.OrdinalIgnoreCase);

            walkCancellation?.Dispose();
            walkCancellation = new CancellationTokenSource();
            var result = await SnmpClient.WalkAsync(walkAgent, walkAgent.CredentialConfig, rootOid, walkCancellation.Token, timeoutMs);
            walkResult = result;

            if (!result.Success)
            {
                walkError = result.ErrorMessage ?? "SNMP Walk failed.";
                return;
            }

            walkLookupByOid = await BuildLookupMapAsync(walkSelectedMibSetId);
            walkTree = BuildWalkTree(result.Items, walkLookupByOid);
            expandedWalkNodes = BuildDefaultExpandedNodes(walkTree);
        }
        catch (OperationCanceledException)
        {
            walkError = "SNMP Walk canceled.";
        }
        catch (Exception ex)
        {
            walkError = ex.Message;
        }
        finally
        {
            walkRunning = false;
            walkCancellation?.Dispose();
            walkCancellation = null;
        }
    }

    private async Task OnWalkMibSetChanged(ChangeEventArgs args)
    {
        walkSelectedMibSetId = ParseMibSetValue(args.Value);
        if (walkResult?.Success != true)
        {
            return;
        }

        walkLookupByOid = await BuildLookupMapAsync(walkSelectedMibSetId);
        walkTree = BuildWalkTree(walkResult.Items, walkLookupByOid);
        expandedWalkNodes = BuildDefaultExpandedNodes(walkTree);
    }

    private void OnGenerateMibSetChanged(ChangeEventArgs args)
    {
        generateSelectedMibSetId = ParseMibSetValue(args.Value);
        pointCandidates = [];
        pointManagerMessage = null;
    }

    private void ToggleWalkNode(string oid)
    {
        if (!expandedWalkNodes.Remove(oid))
        {
            expandedWalkNodes.Add(oid);
        }
    }

    private void ExpandWalkTree() => expandedWalkNodes = BuildAllExpandableNodes(walkTree);

    private void CollapseWalkTree() => expandedWalkNodes = [];

    private async Task RunGenerateCandidatesAsync()
    {
        if (generateAgent is null)
        {
            return;
        }

        try
        {
            var rootOid = NormalizeWalkRootOid(generateRootOid);
            var timeoutMs = NormalizeWalkOperationTimeoutMs(generateOperationTimeoutMs);
            generateRootOid = rootOid;
            generateOperationTimeoutMs = timeoutMs;
            generateError = null;
            pointManagerMessage = null;
            pointCandidates = [];
            generateRunning = true;

            generateCancellation?.Dispose();
            generateCancellation = new CancellationTokenSource();
            var result = await SnmpClient.WalkAsync(generateAgent, generateAgent.CredentialConfig, rootOid, generateCancellation.Token, timeoutMs);
            if (!result.Success)
            {
                generateError = result.ErrorMessage ?? "SNMP Walk failed.";
                return;
            }

            var lookupByOid = await BuildLookupMapAsync(generateSelectedMibSetId);
            pointCandidates = BuildPointCandidates(generateAgent, result.Items, lookupByOid);
        }
        catch (OperationCanceledException)
        {
            generateError = "SNMP Walk canceled.";
        }
        catch (Exception ex)
        {
            generateError = ex.Message;
        }
        finally
        {
            generateRunning = false;
            generateCancellation?.Dispose();
            generateCancellation = null;
        }
    }

    private async Task ApplyGeneratedPointsAsync()
    {
        if (generateAgent is null)
        {
            return;
        }

        try
        {
            var created = 0;
            foreach (var candidate in pointCandidates.Where(c => c.Selected && !c.Exists))
            {
                await Points.CreateOrUpdateAsync(new SnmpPointConfig
                {
                    AgentConfigId = generateAgent.Id,
                    PointName = candidate.PointName,
                    NumericOid = candidate.NumericOid,
                    ValueType = candidate.ValueType,
                    Access = candidate.Access,
                    Description = candidate.Description,
                    MibSetIdUsedForMapping = generateSelectedMibSetId,
                    MibLabel = candidate.Label,
                    MibModule = candidate.Module,
                    MibSyntax = candidate.Syntax,
                    MibAccess = candidate.MibAccess,
                    MibDescription = candidate.Description
                });
                candidate.Exists = true;
                candidate.Selected = false;
                candidate.Status = "created";
                created++;
            }

            await LoadAsync();
            SetPointManagerMessage($"Created {created} point(s).");
        }
        catch (Exception ex)
        {
            SetPointManagerMessage(ex.Message, isError: true);
        }
    }

    private async Task<Dictionary<string, MibLookupResult>> BuildLookupMapAsync(int? mibSetId)
    {
        if (mibSetId is null)
        {
            return new Dictionary<string, MibLookupResult>(StringComparer.OrdinalIgnoreCase);
        }

        var nodes = await MibLookup.ListBySetAsync(mibSetId.Value);
        return nodes
            .GroupBy(n => n.NumericOid, StringComparer.OrdinalIgnoreCase)
            .ToDictionary(g => g.Key, g => g.First(), StringComparer.OrdinalIgnoreCase);
    }

    private List<PointCandidate> BuildPointCandidates(
        SnmpAgentConfig sourceAgent,
        IReadOnlyList<SnmpWalkItem> items,
        IReadOnlyDictionary<string, MibLookupResult> lookupByOid)
    {
        var existingSourcePaths = points.Select(p => p.SourcePath).ToHashSet(StringComparer.OrdinalIgnoreCase);
        var usedNames = points
            .Where(p => p.AgentConfigId == sourceAgent.Id)
            .Select(p => p.PointName)
            .ToHashSet(StringComparer.OrdinalIgnoreCase);
        var candidates = new List<PointCandidate>();

        foreach (var item in items.OrderBy(i => i.Oid, OidPathComparer.Instance))
        {
            var numericOid = NormalizeOidForDisplay(item.Oid);
            var lookup = FindLookupForOid(lookupByOid, numericOid);
            var access = NormalizeAccess(lookup?.Access);
            if (generateReadableOnly && access == SnmpAccessModes.WriteOnly)
            {
                continue;
            }

            var sourcePath = Paths.BuildPointSourcePath(sourceAgent.AgentId, numericOid);
            var exists = existingSourcePaths.Contains(sourcePath);
            var suggestedName = MakeUniquePointName(MakePointName(lookup?.SymbolicName, numericOid), usedNames);
            candidates.Add(new PointCandidate
            {
                Selected = !exists,
                Exists = exists,
                NumericOid = numericOid,
                Label = lookup?.SymbolicName,
                Module = lookup?.ModuleName,
                Syntax = lookup?.Syntax ?? item.Syntax,
                MibAccess = lookup?.Access,
                Access = access,
                CurrentValue = item.Value ?? "",
                PointName = suggestedName,
                ValueType = InferValueType(lookup?.Syntax ?? item.Syntax),
                Description = lookup?.Description,
                Status = exists ? "existing" : "new"
            });
        }

        return candidates;
    }

