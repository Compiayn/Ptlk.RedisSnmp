            MibSetIdUsedForMapping = source.MibSetIdUsedForMapping,
            MibLabel = source.MibLabel,
            MibModule = source.MibModule,
            MibSyntax = source.MibSyntax,
            MibAccess = source.MibAccess,
            MibDescription = source.MibDescription
        };

    private static string SecuritySummary(SnmpCredentialConfig item)
    {
        if (item.Version != SnmpVersions.V3)
        {
            return "read/write community";
        }

        return string.IsNullOrWhiteSpace(item.SecurityLevel)
            ? SnmpSecurityLevels.NoAuthNoPriv
            : item.SecurityLevel;
    }

    private string MibSetName(int? mibSetId)
    {
        if (mibSetId is null)
        {
            return "Numeric OID only";
        }

        return mibSetOptions.FirstOrDefault(s => s.Id == mibSetId)?.Name ?? $"MIB set {mibSetId}";
    }

    private static string MibSetSelectValue(int? mibSetId) =>
        mibSetId?.ToString() ?? "";

    private static int? ParseMibSetValue(object? value) =>
        int.TryParse(Convert.ToString(value), out var parsed) && parsed > 0 ? parsed : null;

    private static string NormalizeAccess(string? mibAccess)
    {
        var normalized = (mibAccess ?? "").Trim().ToLowerInvariant();
        return normalized switch
        {
            "read-write" or "readwrite" or "rw" => SnmpAccessModes.ReadWrite,
            "write-only" or "writeonly" or "wo" => SnmpAccessModes.WriteOnly,
            _ => SnmpAccessModes.ReadOnly
        };
    }

    private static string InferValueType(string? syntax)
    {
        var normalized = (syntax ?? "").Trim().ToLowerInvariant();
        if (normalized.Contains("integer", StringComparison.Ordinal) || normalized.Contains("counter", StringComparison.Ordinal))
        {
            return SnmpValueTypes.Integer;
        }
        if (normalized.Contains("gauge", StringComparison.Ordinal) || normalized.Contains("float", StringComparison.Ordinal) || normalized.Contains("double", StringComparison.Ordinal))
        {
            return SnmpValueTypes.Double;
        }
        if (normalized.Contains("timetick", StringComparison.Ordinal))
        {
            return SnmpValueTypes.Timeticks;
        }
        if (normalized.Contains("object identifier", StringComparison.Ordinal) || normalized == "oid")
        {
            return SnmpValueTypes.Oid;
        }

        return SnmpValueTypes.String;
    }

    private static string MakePointName(string? label, string numericOid)
    {
        var source = string.IsNullOrWhiteSpace(label)
            ? "oid_" + numericOid.Replace(".", "_", StringComparison.Ordinal)
            : label;
        var builder = new System.Text.StringBuilder();
        foreach (var ch in source)
        {
            builder.Append(char.IsLetterOrDigit(ch) || ch is '_' or '-' ? ch : '_');
        }

        var value = builder.ToString().Trim('_');
        return string.IsNullOrWhiteSpace(value) ? "snmp_point" : value;
    }

    private static string MakeUniquePointName(string baseName, HashSet<string> usedNames)
    {
        var candidate = baseName;
        var suffix = 2;
        while (!usedNames.Add(candidate))
        {
            candidate = $"{baseName}_{suffix}";
            suffix++;
        }

        return candidate;
    }

    private static string StatusBadgeClass(string? status)
    {
        var normalized = status?.ToLowerInvariant();
        return normalized switch
        {
            "normal" or "good" or "enabled" => "status-badge success",
            "starting" or "unset" => "status-badge warning",
            "degraded" or "bad" or "failed" or "error" => "status-badge danger",
            _ => "status-badge neutral"
        };
    }

    private static string FormatDate(DateTime value) =>
        value == default ? "-" : value.ToLocalTime().ToString("yyyy-MM-dd HH:mm:ss");

    private static string NormalizeWalkRootOid(string value)
    {
        var oid = NormalizeOidForDisplay(value);
        if (string.IsNullOrWhiteSpace(oid) || oid.Any(ch => !char.IsDigit(ch) && ch != '.') || !oid.Any(char.IsDigit))
        {
            throw new InvalidOperationException("Root OID must be numeric.");
        }

        return oid;
    }

    private static string NormalizeOidForDisplay(string value) => value.Trim().TrimStart('.');

    private static int NormalizeWalkOperationTimeoutMs(int value)
    {
        if (value < 1000)
        {
            throw new InvalidOperationException("Operation timeout must be at least 1000 ms.");
        }

        return value;
    }

    private static List<WalkTreeNode> BuildWalkTree(
        IEnumerable<SnmpWalkItem> items,
        IReadOnlyDictionary<string, MibLookupResult> lookupByOid)
    {
        var roots = new List<WalkTreeNode>();
        var byOid = new Dictionary<string, WalkTreeNode>(StringComparer.Ordinal);

        foreach (var item in items.OrderBy(i => i.Oid, OidPathComparer.Instance))
        {
            var parentChildren = roots;
            var prefix = "";
            foreach (var segment in item.Oid.Trim().TrimStart('.').Split('.', StringSplitOptions.RemoveEmptyEntries))
            {
                prefix = string.IsNullOrEmpty(prefix) ? segment : $"{prefix}.{segment}";
                if (!byOid.TryGetValue(prefix, out var node))
                {
                    node = new WalkTreeNode(segment, prefix);
                    byOid[prefix] = node;
                    parentChildren.Add(node);
                }

                node.Lookup ??= FindLookupForOid(lookupByOid, prefix);
                parentChildren = node.Children;
            }

            if (byOid.TryGetValue(item.Oid.Trim().TrimStart('.'), out var leaf))
            {
                leaf.Item = item;
                leaf.Lookup = FindLookupForOid(lookupByOid, leaf.Oid);
            }
        }

        SortWalkTree(roots);
        return roots;
    }

    private static MibLookupResult? FindLookupForOid(
        IReadOnlyDictionary<string, MibLookupResult> lookupByOid,
        string numericOid)
    {
        var probe = NormalizeOidForDisplay(numericOid);
        while (!string.IsNullOrWhiteSpace(probe))
        {
            if (lookupByOid.TryGetValue(probe, out var lookup))
            {
                return lookup;
            }

            var lastDot = probe.LastIndexOf('.');
            if (lastDot < 0)
            {
                return null;
            }

            probe = probe[..lastDot];
        }

        return null;
    }

    private static void SortWalkTree(List<WalkTreeNode> nodes)
    {
        nodes.Sort((left, right) => OidPathComparer.Instance.Compare(left.Oid, right.Oid));
        foreach (var node in nodes)
        {
            SortWalkTree(node.Children);
        }
    }

    private static IReadOnlyList<WalkTreeRow> FlattenWalkTree(IReadOnlyList<WalkTreeNode> roots, HashSet<string> expanded)
    {
        var rows = new List<WalkTreeRow>();
        foreach (var root in roots)
        {
            AddVisibleNode(root, 0);
        }

        return rows;

        void AddVisibleNode(WalkTreeNode node, int depth)
        {
            rows.Add(new WalkTreeRow(node, depth));
            if (!expanded.Contains(node.Oid))
            {
                return;
            }

            foreach (var child in node.Children)
            {
                AddVisibleNode(child, depth + 1);
            }
        }
    }

    private static HashSet<string> BuildDefaultExpandedNodes(IReadOnlyList<WalkTreeNode> roots)
    {
        var expanded = new HashSet<string>(StringComparer.Ordinal);
        foreach (var root in roots)
        {
            AddDefault(root, 0);
        }

        return expanded;

        void AddDefault(WalkTreeNode node, int depth)
        {
            if (node.Children.Count == 0)
            {
                return;
            }

            if (depth < 4 || (node.Item is null && node.Children.Count == 1))
            {
                expanded.Add(node.Oid);
                foreach (var child in node.Children)
                {
                    AddDefault(child, depth + 1);
                }
            }
        }
    }

    private static HashSet<string> BuildAllExpandableNodes(IReadOnlyList<WalkTreeNode> roots)
    {
        var expanded = new HashSet<string>(StringComparer.Ordinal);
        foreach (var root in roots)
        {
            AddNode(root);
        }

        return expanded;

        void AddNode(WalkTreeNode node)
        {
            if (node.Children.Count > 0)
            {
                expanded.Add(node.Oid);
            }

            foreach (var child in node.Children)
            {
                AddNode(child);
            }
        }
    }

    private sealed class WalkTreeNode(string segment, string oid)
    {
        public string Segment { get; } = segment;
        public string Oid { get; } = oid;
        public SnmpWalkItem? Item { get; set; }
        public MibLookupResult? Lookup { get; set; }
        public List<WalkTreeNode> Children { get; } = [];
    }

    private sealed record WalkTreeRow(WalkTreeNode Node, int Depth);

    private sealed class PointCandidate
    {
        public bool Selected { get; set; }
        public bool Exists { get; set; }
        public string NumericOid { get; set; } = "";
        public string? Label { get; set; }
        public string? Module { get; set; }
        public string? Syntax { get; set; }
        public string Access { get; set; } = SnmpAccessModes.ReadOnly;
        public string? MibAccess { get; set; }
        public string CurrentValue { get; set; } = "";
        public string PointName { get; set; } = "";
        public string ValueType { get; set; } = SnmpValueTypes.String;
        public string? Description { get; set; }
        public string Status { get; set; } = "new";
    }

    private sealed class OidPathComparer : IComparer<string>
    {
        public static readonly OidPathComparer Instance = new();

        public int Compare(string? left, string? right)
        {
            if (ReferenceEquals(left, right))
            {
                return 0;
            }
            if (left is null)
            {
                return -1;
            }
            if (right is null)
            {
                return 1;
            }

            var leftParts = left.Trim().TrimStart('.').Split('.', StringSplitOptions.RemoveEmptyEntries);
            var rightParts = right.Trim().TrimStart('.').Split('.', StringSplitOptions.RemoveEmptyEntries);
            var count = Math.Min(leftParts.Length, rightParts.Length);
            for (var i = 0; i < count; i++)
            {
                var leftNumber = int.TryParse(leftParts[i], out var parsedLeft);
                var rightNumber = int.TryParse(rightParts[i], out var parsedRight);
                var comparison = leftNumber && rightNumber
                    ? parsedLeft.CompareTo(parsedRight)
                    : string.Compare(leftParts[i], rightParts[i], StringComparison.Ordinal);
                if (comparison != 0)
                {
                    return comparison;
                }
            }

            return leftParts.Length.CompareTo(rightParts.Length);
        }
    }
}
