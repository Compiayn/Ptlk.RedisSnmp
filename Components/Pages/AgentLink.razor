    private IReadOnlyList<WalkTreeRow> VisibleWalkRows => FlattenWalkTree(walkTree, expandedWalkNodes);
    private IReadOnlyList<SnmpPointConfig> ManagedAgentPoints =>
        generateAgent is null
            ? Array.Empty<SnmpPointConfig>()
