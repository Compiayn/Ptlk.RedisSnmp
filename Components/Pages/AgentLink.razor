    private async Task ConfirmDeleteAsync()
    {
        try
        {
            var deleted = deleteKind;
            var showPointManagerMessage = deleted == "point" && generateDialogOpen && generateAgent is not null;
            switch (deleteKind)
            {
                case "credential":
