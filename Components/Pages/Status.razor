@page "/status"
@rendermode InteractiveServer
@inject RuntimeModeService Runtime
@inject RedisPointOwnershipService Ownership

<div class="page-header">
    <div>
        <h1>Status</h1>
        <p class="page-kicker">Runtime connectivity, Asset readiness, and current ownership claims.</p>
    </div>
    <button class="btn btn-outline-primary" type="button" @onclick="Refresh">Refresh</button>
</div>

<section class="surface">
    <div class="row g-3">
        <div class="col-md-3">
            <div class="muted-metadata">Mode</div>
            <span class="@StatusBadgeClass(state.Mode.ToString())">@state.Mode</span>
        </div>
        <div class="col-md-3">
            <div class="muted-metadata">Redis connected</div>
            <span class="@StatusBadgeClass(state.RedisConnected ? "normal" : "degraded")">@state.RedisConnected</span>
        </div>
        <div class="col-md-3">
            <div class="muted-metadata">Asset initialized</div>
            <span class="@StatusBadgeClass(state.AssetInitialized ? "normal" : "degraded")">@state.AssetInitialized</span>
        </div>
        <div class="col-md-3">
            <div class="muted-metadata">Runtime updated</div>
            <div class="numeric">@state.UpdatedAt.LocalDateTime.ToString("yyyy-MM-dd HH:mm:ss")</div>
        </div>
    </div>
    <hr />
    <div>@state.Message</div>
</section>

<div class="toolbar">
    <div>
        <h2 class="toolbar-title">Ownership</h2>
        <div class="muted-metadata">This snapshot is local runtime state; use Refresh to re-render the current claims.</div>
    </div>
</div>

@if (claims.Count == 0)
{
    <div class="empty-state">No ownership claims are currently tracked.</div>
}
else
{
    <div class="table-responsive">
        <table class="table table-sm data-table align-middle">
            <thead>
                <tr>
                    <th>Source</th>
                    <th>Redis key</th>
                    <th>Status</th>
                    <th>Owner</th>
                </tr>
            </thead>
            <tbody>
            @foreach (var claim in claims)
            {
                <tr>
                    <td><code>@claim.SourcePath</code></td>
                    <td><code>@claim.RedisKey</code></td>
                    <td><span class="@StatusBadgeClass(claim.Status)">@claim.Status</span></td>
                    <td>@(claim.Owner ?? "-")</td>
                </tr>
            }
            </tbody>
        </table>
    </div>
}

@code {
    private RuntimeState state = default!;
    private IReadOnlyCollection<PointOwnershipClaimResult> claims = [];

    protected override void OnInitialized() => Refresh();

    private void Refresh()
    {
        state = Runtime.Current;
        claims = Ownership.Snapshot();
    }

    private static string StatusBadgeClass(string? status)
    {
        var normalized = status?.ToLowerInvariant();
        return normalized switch
        {
            "normal" or "good" or "owned" or "claimed" or "success" or "true" => "status-badge success",
            "starting" or "unset" or "pending" => "status-badge warning",
            "degraded" or "bad" or "failed" or "owned_by_other" or "missing_key" or "false" => "status-badge danger",
            _ => "status-badge neutral"
        };
    }
}
