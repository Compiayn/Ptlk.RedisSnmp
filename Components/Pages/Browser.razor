@page "/browser"
@rendermode InteractiveServer
@implements IAsyncDisposable
@inject Microsoft.Extensions.Options.IOptions<Ptlk.RedisSnmp.Configuration.BrowserOptions> BrowserSettings
@inject BrowserSnapshotService SnapshotService
@inject CommandDispatcherService Dispatcher
@inject CommandExecutionService Commands
@inject ScreenAlertService ScreenAlerts

<div class="page-header">
    <div>
        <h1>Browser</h1>
        <p class="page-kicker">Runtime snapshot of local SNMP cache, Redis point state, and ownership.</p>
    </div>
    <button class="btn btn-outline-primary" type="button" @onclick="RequestRefreshAsync" disabled="@isLoading">@(isLoading ? "Refreshing" : "Refresh")</button>
</div>

<ScreenAlertHost />

@if (lastLoaded is not null)
{
    <div class="muted-metadata mb-3">Snapshot refreshed @lastLoaded.Value.LocalDateTime.ToString("yyyy-MM-dd HH:mm:ss").</div>
}

@if (isLoading && !hasLoaded)
{
    <div class="empty-state">Loading browser snapshot...</div>
}
else if (rows.Count == 0)
{
    <div class="empty-state">No SNMP points are configured, so no runtime values can be displayed.</div>
}
else
{
    <div class="table-responsive">
        <table class="table table-sm data-table align-middle">
            <thead>
                <tr>
                    <th>Agent</th>
                    <th>Point</th>
                    <th>Local value</th>
                    <th>Local quality</th>
                    <th>Local updated</th>
                    <th>Redis state</th>
                    <th>Ownership</th>
                    <th class="actions">Write</th>
                </tr>
            </thead>
            <tbody>
            @foreach (var row in rows)
            {
                var canWrite = SnmpAccessModes.CanWrite(row.Access);
                <tr>
                    <td>@row.AgentId</td>
                    <td>
                        <div>@row.DisplayName</div>
                        <small>@row.SourcePath</small>
                    </td>
                    <td class="numeric">@DisplayValue(row.LocalValue)</td>
                    <td>
                        <span class="@StatusBadgeClass(row.LocalQuality)">@row.LocalQuality</span>
                        @if (!string.IsNullOrWhiteSpace(row.LastError))
                        {
                            <div><small>@row.LastError</small></div>
                        }
                    </td>
                    <td class="numeric">@FormatTimestamp(row.LocalTimestamp)</td>
                    <td>
                        @if (row.RedisKey is null)
                        {
                            <span class="status-badge neutral">unmapped</span>
                        }
                        else
                        {
                            <div><code>@row.RedisKey</code></div>
                            @if (row.RedisState is null)
                            {
                                <small>Redis state unavailable.</small>
                            }
                            else
                            {
                                <small>
                                    <span class="@StatusBadgeClass(row.RedisState.Quality)">@row.RedisState.Quality</span>
                                    v<span class="numeric">@row.RedisState.Version</span>
                                    @FormatUnixMs(row.RedisState.Timestamp)
                                </small>
                            }
                        }
                    </td>
                    <td><span class="@StatusBadgeClass(row.Owned ? "owned" : row.OwnershipStatus)">@OwnershipText(row)</span></td>
                    <td class="actions">
                        <div class="input-group input-group-sm">
                            <input class="form-control" placeholder="value" @bind="writeValues[row.SourcePath]" disabled="@(!canWrite)" />
                            <button class="btn btn-outline-secondary" type="button" disabled="@(!canWrite)" @onclick="() => WriteSnmpAsync(row.SourcePath)">SNMP</button>
                            @if (row.RedisKey is not null)
                            {
                                <button class="btn btn-outline-primary" type="button" disabled="@(!row.Owned || !canWrite)" @onclick="() => WriteRedisAsync(row)">Redis</button>
                            }
                        </div>
                    </td>
                </tr>
            }
            </tbody>
        </table>
    </div>
}

@code {
    private IReadOnlyList<BrowserPointSnapshot> rows = [];
    private Dictionary<string, string> writeValues = new(StringComparer.OrdinalIgnoreCase);
    private readonly SemaphoreSlim refreshGate = new(1, 1);
    private readonly object debounceLock = new();
    private CancellationTokenSource? pageCancellation;
    private CancellationTokenSource? debounceCancellation;
    private Task? refreshLoopTask;
    private string? lastSnapshotAlertMessage;
    private bool isLoading;
    private bool hasLoaded;
    private bool disposed;
    private DateTimeOffset? lastLoaded;

    private TimeSpan RefreshInterval => TimeSpan.FromMilliseconds(BrowserSettings.Value.RefreshIntervalMs > 0
        ? BrowserSettings.Value.RefreshIntervalMs
        : 1000);

    protected override async Task OnInitializedAsync()
    {
        pageCancellation = new CancellationTokenSource();
        await RefreshSnapshotAsync(pageCancellation.Token);
        refreshLoopTask = RunRefreshLoopAsync(pageCancellation.Token);
    }

    private async Task RequestRefreshAsync()
    {
        QueueDebouncedRefresh();
        await Task.CompletedTask;
    }

    private void QueueDebouncedRefresh()
    {
        if (disposed || pageCancellation is null)
        {
            return;
        }

        CancellationTokenSource current;
        CancellationTokenSource? previous;
        lock (debounceLock)
        {
            previous = debounceCancellation;
            current = CancellationTokenSource.CreateLinkedTokenSource(pageCancellation.Token);
            debounceCancellation = current;
        }

        previous?.Cancel();
        _ = RunDebouncedRefreshAsync(current);
    }

    private async Task RunDebouncedRefreshAsync(CancellationTokenSource refreshCancellation)
    {
        try
        {
            await Task.Delay(RefreshInterval, refreshCancellation.Token);
            await RefreshSnapshotAsync(refreshCancellation.Token);
        }
        catch (OperationCanceledException) when (refreshCancellation.IsCancellationRequested)
        {
        }
        finally
        {
            lock (debounceLock)
            {
                if (ReferenceEquals(debounceCancellation, refreshCancellation))
                {
                    debounceCancellation = null;
                }
            }

            refreshCancellation.Dispose();
        }
    }

    private async Task RunRefreshLoopAsync(CancellationToken cancellationToken)
    {
        try
        {
            using var timer = new PeriodicTimer(RefreshInterval);
            while (await timer.WaitForNextTickAsync(cancellationToken))
            {
                await RefreshSnapshotAsync(cancellationToken);
            }
        }
        catch (OperationCanceledException) when (cancellationToken.IsCancellationRequested)
        {
        }
    }

    private async Task RefreshSnapshotAsync(CancellationToken cancellationToken)
    {
        if (!await refreshGate.WaitAsync(0, cancellationToken))
        {
            return;
        }

        try
        {
            isLoading = true;
            await InvokeAsync(StateHasChanged);
            var snapshot = await SnapshotService.SnapshotAsync(cancellationToken);
            rows = snapshot;
            lastLoaded = DateTimeOffset.Now;
            lastSnapshotAlertMessage = null;
            foreach (var row in rows)
            {
                writeValues.TryAdd(row.SourcePath, "");
            }

            hasLoaded = true;
        }
        catch (OperationCanceledException) when (cancellationToken.IsCancellationRequested)
        {
        }
        catch (Exception ex)
        {
            await ShowSnapshotErrorAsync(ex);
        }
        finally
        {
            isLoading = false;
            refreshGate.Release();
            await InvokeAsync(StateHasChanged);
        }
    }

    private async Task WriteSnmpAsync(string sourcePath)
    {
        try
        {
            var result = await Commands.DirectSnmpWriteAsync(sourcePath, writeValues.GetValueOrDefault(sourcePath) ?? "", "browser", pageCancellation?.Token ?? CancellationToken.None);
            await ShowWriteResultAsync("SNMP write", result.Status, result.Message);
            QueueDebouncedRefresh();
        }
        catch (Exception ex)
        {
            await ScreenAlerts.ShowAsync(ex.Message, ScreenAlertSeverity.Error, "SNMP write failed");
        }
    }

    private async Task WriteRedisAsync(BrowserPointSnapshot row)
    {
        if (row.RedisKey is null)
        {
            return;
        }

        try
        {
            var mapping = new Ptlk.RedisSnmp.Models.RedisMapping { SourcePath = row.SourcePath, RedisKey = row.RedisKey };
            var result = await Dispatcher.DispatchHmiWriteAsync(mapping, writeValues.GetValueOrDefault(row.SourcePath) ?? "", "browser", pageCancellation?.Token ?? CancellationToken.None);
            await ShowWriteResultAsync("Redis write", result.Status, result.Message);
            QueueDebouncedRefresh();
        }
        catch (Exception ex)
        {
            await ScreenAlerts.ShowAsync(ex.Message, ScreenAlertSeverity.Error, "Redis write failed");
        }
    }

    private async Task ShowSnapshotErrorAsync(Exception ex)
    {
        if (string.Equals(lastSnapshotAlertMessage, ex.Message, StringComparison.Ordinal))
        {
            return;
        }

        lastSnapshotAlertMessage = ex.Message;
        await ScreenAlerts.ShowAsync(ex.Message, ScreenAlertSeverity.Error, "Snapshot refresh failed");
    }

    private Task ShowWriteResultAsync(string operation, string status, string message)
    {
        var failed = status.Equals("failed", StringComparison.OrdinalIgnoreCase);
        return ScreenAlerts.ShowAsync(
            $"{status}: {message}",
            failed ? ScreenAlertSeverity.Error : ScreenAlertSeverity.Success,
            failed ? $"{operation} failed" : $"{operation} completed");
    }

    public async ValueTask DisposeAsync()
    {
        disposed = true;
        pageCancellation?.Cancel();

        lock (debounceLock)
        {
            debounceCancellation?.Cancel();
        }

        if (refreshLoopTask is not null)
        {
            try
            {
                await refreshLoopTask;
            }
            catch (OperationCanceledException)
            {
            }
        }

        pageCancellation?.Dispose();
        refreshGate.Dispose();
    }

    private static string DisplayValue(string? value) =>
        string.IsNullOrWhiteSpace(value) ? "-" : value;

    private static string FormatTimestamp(DateTimeOffset? value) =>
        value is null ? "-" : value.Value.LocalDateTime.ToString("yyyy-MM-dd HH:mm:ss");

    private static string FormatUnixMs(long value) =>
        value <= 0 ? "-" : DateTimeOffset.FromUnixTimeMilliseconds(value).LocalDateTime.ToString("yyyy-MM-dd HH:mm:ss");

    private static string OwnershipText(BrowserPointSnapshot row) =>
        row.Owned ? "owned" : row.OwnershipStatus ?? "not owned";

    private static string StatusBadgeClass(string? status)
    {
        var normalized = status?.ToLowerInvariant();
        return normalized switch
        {
            "normal" or "good" or "owned" or "completed" or "accepted" => "status-badge success",
            "starting" or "unset" or "pending" or "unmapped" => "status-badge warning",
            "degraded" or "bad" or "failed" or "timeout" or "missing" or "owned_by_other" or "missing_key" => "status-badge danger",
            _ => "status-badge neutral"
        };
    }
}
